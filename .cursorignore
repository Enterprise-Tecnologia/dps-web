# ===============================
# Arquivos de build / dependências
# ===============================
node_modules/
.next/
out/
dist/
build/
.cache/
.vercel/

# ===============================
# Arquivos do sistema / OS
# ===============================
.DS_Store
Thumbs.db
desktop.ini

# ===============================
# Logs
# ===============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ===============================
# Ambiente (não deixar IA ler secrets)
# ===============================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.example

# ===============================
# Configs que não precisam ser analisadas
# ===============================
.vscode/
.idea/
*.iml

# ===============================
# Arquivos de lock (pesados e inúteis para IA)
# ===============================
package-lock.json
pnpm-lock.yaml
yarn.lock
bun.lockb

# ===============================
# Pastas de imagens, PDFs e arquivos grandes
# (a IA não precisa disso para programar)
# ===============================
public/images/**
public/assets/**
public/static/**
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.pdf

# ===============================
# Caches do Next e ferramentas
# ===============================
.next/
.eslintcache
.stylelintcache
tailwind.config.js.*
postcss.config.js.*
jest-cache/
coverage/
